APP_ENV=production
APP_NAME="Helios University Academic Hub"
APP_URL=https://your-render-service.onrender.com

# Aiven MySQL. Use the Service URI from Aiven and keep ssl-mode enabled.
DATABASE_URL=mysql://avnadmin:your-aiven-password@your-aiven-host.aivencloud.com:12345/defaultdb?ssl-mode=verify-ca
DB_CHARSET=utf8mb4

# Aiven TLS. Pick one certificate option:
# 1) MYSQL_SSL_CA = path to a Render secret file containing Aiven ca.pem
# 2) AIVEN_CA_CERT_BASE64 = base64-encoded contents of Aiven ca.pem
MYSQL_SSL_MODE=verify-ca
MYSQL_SSL_CA=
AIVEN_CA_CERT_BASE64=

# Keep this stable after users are created; changing it breaks encrypted email/phone values.
HELIOS_SECRET_KEY=replace-with-a-long-random-secret

# Gmail/SMTP sender for OTP and approval emails.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-gmail-app-password
SMTP_FROM_EMAIL=your-email@gmail.com
SMTP_FROM_NAME="Helios University Academic Hub"

# Twilio Verify for SMS OTP.
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_VERIFY_SERVICE_SID=your-twilio-verify-service-sid

# One-time admin bootstrap. Set these before running: php tools/create_admin.php
ADMIN_EMAIL=your-admin-email@example.com
ADMIN_PHONE=09XXXXXXXXX
ADMIN_PASSWORD=your-secure-admin-password
ADMIN_USERNAME=26-0001
ADMIN_FIRSTNAME=System
ADMIN_LASTNAME=Administrator
