APP_ENV=production
APP_NAME="Helios University Academic Hub"
APP_URL=https://your-render-service.onrender.com

# Use one URL or the individual DB_* values below.
DATABASE_URL=mysql://username:password@host:3306/database_name
DB_HOST=localhost
DB_PORT=3306
DB_NAME=helios_db
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

# Keep this stable after users are created; changing it breaks encrypted email/phone values.
HELIOS_SECRET_KEY=replace-with-a-long-random-secret

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=your-email@gmail.com
SMTP_FROM_NAME="Helios University Academic Hub"

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=
